        "pattern": "\\bnanobot\\s+gateway\\s+--background\\b",
        "minimum_occurrences": 1
      },
      {
        "id": "gateway-status",
        "pattern": "\\bnanobot\\s+gateway\\s+status\\b",
        "minimum_occurrences": 1
      },

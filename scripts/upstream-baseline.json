        "minimum_occurrences": 1
      },
      {
        "id": "gateway-restart",
        "pattern": "\\bnanobot\\s+gateway\\s+restart\\b",
        "minimum_occurrences": 1
      },
      {
        "id": "gateway-stop",
        "pattern": "\\bnanobot\\s+gateway\\s+stop\\b",
        "minimum_occurrences": 1
      },
      {
        "id": "gateway-install-service",
        "pattern": "\\bnanobot\\s+gateway\\s+install-service\\b",
        "minimum_occurrences": 1
      }
    ],
    "forbidden": [
      {
        "id": "agent-verbose",
        "pattern": "\\bnanobot\\s+agent\\s+(?:--verbose|-v)(?=\\s|[^A-Za-z0-9_-]|$)",
        "reason": "v0.2.2 uses nanobot agent --logs for runtime diagnostics"
      },
      {
        "id": "legacy-log-env",
        "pattern": "\\bNANOBOT_LOG_LEVEL\\b",
        "reason": "the tutorial must not advertise the removed logging environment variable"
      }
    ]
  },
  "legacy_path_assertions": [
    {
      "id": "legacy-requirements",
      "pattern": "\\brequirements-docs\\.txt\\b",
      "reason": "documentation dependencies live in requirements.txt"
    },
    {
      "id": "legacy-hero-directory",
      "pattern": "(?<![A-Za-z0-9_/])build/(?:README|0[1-6]-)[A-Za-z0-9_.-]*\\.md",
      "reason": "Hero chapters live under docs/zh-cn/hero"
    },
    {
      "id": "legacy-appendix-path",
      "pattern": "\\bappendix-(?:environment-precheck|troubleshooting(?:-guide)?)\\.md\\b",
      "reason": "appendices live under docs/zh-cn/appendix"
    },
    {
      "id": "legacy-example-directory",
      "pattern": "(?:docs/zh-cn/)?examples/(?!hero(?:/|\\b))",
      "reason": "the maintained teaching snapshots live under docs/zh-cn/examples/hero"
    },
    {
      "id": "legacy-history-file",
      "pattern": "(?<![A-Za-z0-9_])HISTORY\\.md\\b",
      "reason": "the maintained history store is memory/history.jsonl"
    }
  ],
  "tools_bootstrap_assertion": {
    "positive_patterns": [
      "BOOTSTRAP_FILES\\s*=\\s*\\[[^\\]]*TOOLS\\.md",
      "(?:Bootstrap|启动配置文件)[^\\n]{0,180}TOOLS\\.md",
      "TOOLS\\.md[^\\n]{0,140}(?:自动(?:加载|读取|注入)|(?:作为|属于|是)[^\\n]{0,40}Bootstrap)"
    ],
    "negative_markers": [
      "不是",
      "并非",
      "不再",
      "不会",
      "不从",
      "不要",
      "未被",
      "删除",
      "禁止",
      "误述",
      "不存在"
    ]
  }

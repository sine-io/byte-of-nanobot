  "command_assertions": {
    "required": [
      {
        "id": "onboard-wizard",
        "pattern": "\\bnanobot\\s+onboard\\s+--wizard\\b",
        "minimum_occurrences": 1
      },
      {
        "id": "status",
        "pattern": "\\bnanobot\\s+status\\b",
